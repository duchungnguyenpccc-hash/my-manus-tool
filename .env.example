# =============================
# Core app
# =============================
NODE_ENV=development
LOCAL_DEV_MODE=true
VITE_LOCAL_DEV_MODE=true
PORT=3000
DATABASE_URL=mysql://root:password@127.0.0.1:3306/faceless_pov_ai
JWT_SECRET=change-this-in-production
OWNER_OPEN_ID=

# =============================
# OAuth / Auth
# =============================
VITE_APP_ID=local-dev-app
OAUTH_SERVER_URL=http://localhost:3000
VITE_OAUTH_PORTAL_URL=http://localhost:3000

# =============================
# Optional analytics (Umami)
# Leave empty for local development
# =============================
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=local-dev

# =============================
# Built-in forge storage (optional)
# =============================
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# =============================
# Data Plane (optional for local)
# =============================
REDIS_URL=
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# =============================
# Local provider endpoints (optional)
# =============================
OLLAMA_BASE_URL=http://127.0.0.1:11434
STABLE_DIFFUSION_URL=http://127.0.0.1:7860
COQUI_TTS_URL=http://127.0.0.1:5002
VIRAL_SCORE_THRESHOLD=65

# =============================
# AI / Media providers (required for full pipeline)
# =============================
OPENAI_API_KEY=
PIAPI_API_KEY=
ELEVENLABS_API_KEY=
CREATOMATE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
